# Copy to .env.local and fill in. Next.js loads .env.local automatically; the
# eval/run.ts tsx script reads it via its own lightweight loader.

# Google AI Studio API key.
GEMINI_API_KEY=
GEMINI_DRAFT_MODEL=gemini-2.5-flash
GEMINI_VERIFY_MODEL=gemini-2.5-flash

# Notion internal integration token (Step 6 — publisher).
NOTION_INTEGRATION_TOKEN=

# Notion parent page ID for "Relay Drafts" (Step 6 — publisher).
NOTION_DRAFTS_PAGE_ID=
